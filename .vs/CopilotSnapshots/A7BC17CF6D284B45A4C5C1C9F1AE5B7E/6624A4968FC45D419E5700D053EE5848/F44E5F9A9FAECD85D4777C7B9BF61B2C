<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMP COEM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar shadow-lg">
            <div class="sidebar-header border-bottom">
                <img src="~/images/logo-coem.png" alt="COEM" style="max-height: 45px; width: auto;">
                </div>

                <nav class="sidebar-menu mt-4">
                    <div class="menu-category">Visión General</div>
                    <a href="/" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>

                    <div class="menu-category">Gobernanza</div>
                    <a href="/Admin/Users" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                        <i class="bi bi-shield-lock-fill"></i> Identidades
                    </a>
                    <a href="/Admin/Tenants" class="nav-link-custom">
                        <i class="bi bi-building-fill"></i> Organizaciones
                    </a>
                    <a href="/Admin/Countries" class="nav-link-custom">
                        <i class="bi bi-building-fill"></i> Preventas
                    </a>

                    <a href="/Admin/CategoryMappings" class="nav-link-custom">
                        <i class="bi bi-building-fill"></i> Categorias Suscripciones
                    </a>

                    <div class="menu-category">Operaciones</div>
                    <a href="/Admin/Billing" class="nav-link-custom">
                        <i class="bi bi-graph-up-arrow"></i> FinOps Global
                    </a>
                </nav>

                <div class="sidebar-footer border-top p-3">
                    @{
                        // EL INTERCEPTOR: Extrae el nombre real del token. Si falla, usa el UPN.
                        var displayName = User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "Usuario";
                        var userInitial = displayName.FirstOrDefault().ToString().ToUpper();
                    }
                
                    <div class="d-flex align-items-center gap-3">
                        <div class="avatar-container">
                            <img src="/Profile/GetPhoto" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" alt="User" class="avatar-img shadow-sm">
                            <div class="avatar-initials" style="display:none;">
                                @userInitial
                            </div>
                        </div>
                        <div class="user-info text-truncate">
                            <div class="fw-bold text-white small" title="@displayName">@displayName</div>
                            <div class="text-white-50" style="font-size: 0.7rem;">Sesión Entra ID</div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="main-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>