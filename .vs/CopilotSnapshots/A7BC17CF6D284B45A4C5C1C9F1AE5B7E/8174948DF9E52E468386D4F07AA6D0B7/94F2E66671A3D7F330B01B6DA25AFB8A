using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Graph;
using Microsoft.Identity.Web;
using Microsoft.Extensions.Logging;
using System;
using System.Threading.Tasks;

namespace Coem.Cmp.Web.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    public class ProfileController : ControllerBase
    {
        private readonly GraphServiceClient _graphServiceClient;
        private readonly ILogger<ProfileController> _logger;

        public ProfileController(
            GraphServiceClient graphServiceClient,
            ILogger<ProfileController> logger)
        {
            _graphServiceClient = graphServiceClient;
            _logger = logger;
        }

        /// <summary>
        /// Obtiene la foto del usuario autenticado desde Microsoft Graph
        /// REQUERIDA AUTENTICACIÓN
        /// </summary>
        [HttpGet("photo")]
        [Authorize]
        public async Task<IActionResult> GetPhoto()
        {
            try
            {
                var userPrincipalName = User.GetDisplayName() ?? User.Identity?.Name;
                _logger.LogInformation($"[ProfileController] Obteniendo foto para usuario: {userPrincipalName}");

                // Obtener la foto del usuario autenticado
                var photoStream = await _graphServiceClient.Me.Photo.Content.GetAsync();

                if (photoStream != null && photoStream.Length > 0)
                {
                    _logger.LogInformation($"[ProfileController] Foto obtenida exitosamente. Tamaño: {photoStream.Length} bytes");
                    return File(photoStream, "image/jpeg", "avatar.jpg");
                }

                _logger.LogWarning("[ProfileController] El stream de foto está vacío o es nulo");
                return NotFound();
            }
            catch (Exception ex) when (ex.Message.Contains("ImageNotFound", StringComparison.OrdinalIgnoreCase))
            {
                _logger.LogInformation($"[ProfileController] Usuario no tiene foto establecida");
                return NotFound();
            }
            catch (Exception ex) when (ex.Message.Contains("user_null", StringComparison.OrdinalIgnoreCase))
            {
                _logger.LogError($"[ProfileController] No hay sesión de usuario activa: {ex.Message}");
                return Unauthorized(new { error = "No hay sesión activa" });
            }
            catch (Exception ex)
            {
                _logger.LogError($"[ProfileController] Error al obtener foto: {ex.GetType().Name} - {ex.Message}");
                return StatusCode(500, new { error = ex.Message });
            }
        }

        /// <summary>
        /// Endpoint de debugging - muestra información del usuario autenticado
        /// </summary>
        [HttpGet("debug")]
        [Authorize]
        public IActionResult GetDebugInfo()
        {
            try
            {
                var claimsList = new System.Collections.Generic.Dictionary<string, string>();

                foreach (var claim in User.Claims)
                {
                    claimsList[claim.Type] = claim.Value;
                }

                return Ok(new
                {
                    authenticated = User.Identity?.IsAuthenticated ?? false,
                    name = User.Identity?.Name,
                    displayName = User.GetDisplayName(),
                    claimsCount = claimsList.Count,
                    selectedClaims = new
                    {
                        objectId = User.GetObjectId(),
                        tenantId = User.GetTenantId(),
                        upn = User.GetUserPrincipalName(),
                        email = User.GetMail()
                    }
                });
            }
            catch (Exception ex)
            {
                return Ok(new { error = ex.Message });
            }
        }
    }
}
