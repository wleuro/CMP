@model Coem.Cmp.Web.Components.UserProfileViewModel
@using System.Security.Claims

@{
    var isGlobalAdmin = Model.Role == "GlobalAdmin";
}

@* CSS Específico para el Avatar Táctico *@
<style>
    .avatar-container {
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        position: relative;
    }

    .avatar-image {
        width: 100%;
        height: 100%;
        border-radius: 8px; /* Mismo radio que el avatar-box previo */
        object-fit: cover; /* Asegura que la foto no se deforme */
        border: 2px solid rgba(255,255,255,0.1);
    }

    /* Fallback de iniciales si no hay foto */
    .avatar-initials-fallback {
        width: 100%;
        height: 100%;
        background: #3b82f6; /* var(--accent-color) */
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
    }
</style>

<div class="d-flex align-items-center gap-3">
    <div class="avatar-container">
        @if (!string.IsNullOrEmpty(Model.PhotoBase64))
        {
            <img src="@Model.PhotoBase64" alt="@Model.DisplayName" class="avatar-image" title="@Model.DisplayName" />
        }
        else
        {
            <div class="avatar-initials-fallback">@Model.Initials</div>
        }
    </div>
    <div class="user-info text-truncate">
        <div class="fw-bold text-white small" title="@Model.DisplayName">@Model.DisplayName</div>
        <div class="text-white-50" style="font-size: 0.7rem;">Rol: @Model.Role</div>
    </div>
</div>