@using System.Security.Claims
@using System.Security.Principal

@{
    // Extraemos el nombre real del usuario del token de Entra ID
    var fullName = User.Claims.FirstOrDefault(c => c.Type == "name")?.Value
                   ?? User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.GivenName)?.Value
                   ?? User.Identity?.Name
                   ?? "Usuario";
}

<ul class="navbar-nav">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <li class="nav-item">
            <span class="nav-link text-dark fw-bold">
                👤 @fullName
            </span>
        </li>
        <li class="nav-item">
            <a class="nav-link text-danger" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">Cerrar Sesión</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-primary fw-bold" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">Iniciar Sesión</a>
        </li>
    }
</ul>