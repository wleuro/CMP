@using Microsoft.AspNetCore.Authorization
@using Coem.Cmp.Core.Interfaces
@inject IAuthorizationService AuthorizationService
@inject ITenantContext TenantContext

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMP COEM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar shadow-lg">
            <div class="sidebar-header border-bottom">
                <img src="~/images/logo-coem.png" alt="COEM" style="max-height: 45px; width: auto;">
                </div>

                <div class="p-2 text-center" style="background-color: rgba(255,255,255,0.05); font-size: 0.75rem;">
                    @if (TenantContext.Scope == "Global")
                    {
                        <span class="badge bg-danger w-100">ACCESO GLOBAL</span>
                    }
                    else if (TenantContext.Scope == "Regional")
                    {
                        <span class="badge bg-primary w-100">REGIÓN: @TenantContext.CurrentCountry</span>
                    }
                    else if (TenantContext.Scope == "SingleTenant")
                    {
                        <span class="badge bg-success w-100">CLIENTE MODO SEGURO</span>
                    }
                </div>

                <nav class="sidebar-menu mt-3">
                    <div class="menu-category">Visión General</div>
                    <a href="/" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>

                    @if ((await AuthorizationService.AuthorizeAsync(User, "TenantSetup")).Succeeded)
                    {
                        <div class="menu-category mt-3 text-warning">Setup & Habilitación</div>
                        <a href="/Admin/Users" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                            <i class="bi bi-shield-lock-fill"></i> Identidades Coem
                        </a>
                        <a href="/Admin/Tenants" class="nav-link-custom">
                            <i class="bi bi-building-fill"></i> Organizaciones / Logos
                        </a>
                        <a href="/Admin/Countries" class="nav-link-custom">
                            <i class="bi bi-globe-americas"></i> Preventas / Territorios
                        </a>
                        <a href="/Admin/CategoryMappings" class="nav-link-custom">
                            <i class="bi bi-tags-fill"></i> Categorías Suscripciones
                        </a>
                    }

                    @if ((await AuthorizationService.AuthorizeAsync(User, "ViewBaseCosts")).Succeeded)
                    {
                        <div class="menu-category mt-3">Negocio Coem</div>
                        <a href="/Admin/Billing" class="nav-link-custom">
                            <i class="bi bi-graph-up-arrow"></i> Reportes FinOps
                        </a>
                    }

                    @if ((await AuthorizationService.AuthorizeAsync(User, "ManageMarkups")).Succeeded)
                    {
                        <a href="/Admin/Pricing" class="nav-link-custom text-warning fw-bold">
                            <i class="bi bi-currency-dollar"></i> Fijación de Markups
                        </a>
                    }

                    @if (TenantContext.Scope == "SingleTenant" && TenantContext.Role == "Client Admin")
                    {
                        <div class="menu-category mt-3">Mi Empresa</div>
                        <a href="/Client/Users" class="nav-link-custom">
                            <i class="bi bi-people-fill"></i> Gestionar mi Equipo
                        </a>
                    }
                </nav>

                <div class="sidebar-footer border-top p-3">
                    @{
                        var displayName = User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "Usuario";
                        var userInitial = displayName.FirstOrDefault().ToString().ToUpper();
                        var userRole = TenantContext.Role ?? "Invitado";
                    }
            
                    <div class="d-flex align-items-center gap-3">
                        <div class="avatar-container">
                            <div class="avatar-initials">
                                @userInitial
                            </div>
                        </div>
                        <div class="user-info text-truncate">
                            <div class="fw-bold text-white small" title="@displayName">@displayName</div>
                            <div class="text-white-50" style="font-size: 0.7rem;">Rol: @userRole</div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="main-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>