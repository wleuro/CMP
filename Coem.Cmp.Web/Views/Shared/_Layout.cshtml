@using Microsoft.AspNetCore.Authorization
@using Coem.Cmp.Core.Interfaces
@using System.Security.Claims
@inject IAuthorizationService AuthorizationService
@inject ITenantContext TenantContext

@{
    var userRole = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Invitado";
    var isGlobalAdmin = userRole == "GlobalAdmin";
    var displayName = User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMP COEM</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --sidebar-bg: #0f172a;
            --accent-color: #3b82f6;
            --admin-gold: #fbbf24;
            --text-muted: #94a3b8;
        }

        /* RESET ESTRUCTURAL */
        html, body { height: 100%; margin: 0; padding: 0; overflow-x: hidden; }

        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }

        /* Contenedor Maestro: No-Wrap Innegociable */
        .app-wrapper { 
            display: flex; 
            flex-direction: row;
            flex-wrap: nowrap;
            min-height: 100vh; 
            width: 100%;
        }

        /* Sidebar Táctico */
        .sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            max-width: var(--sidebar-width);
            background-color: var(--sidebar-bg);
            color: #fff;
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-header { padding: 1.5rem; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-menu { flex-grow: 1; overflow-y: auto; padding-top: 1rem; }

        .menu-category {
            padding: 1.5rem 1.5rem 0.5rem;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            color: #cbd5e1;
            text-decoration: none;
            border-left: 4px solid transparent;
            transition: 0.2s;
        }

        .nav-link-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-link-custom.active { background: rgba(59, 130, 246, 0.1); color: #fff; border-left-color: var(--accent-color); }
        .nav-link-custom i { margin-right: 12px; font-size: 1.1rem; }
        
        .nav-link-admin { color: var(--admin-gold) !important; font-weight: 600; }
        .nav-link-admin:hover { background: rgba(251, 191, 36, 0.1) !important; }

        /* Contenido Principal: El Fix */
        .main-content { 
            flex-grow: 1; 
            flex-shrink: 1;
            min-width: 0; /* ESTO evita que el contenido empuje el sidebar abajo */
            display: flex; 
            flex-direction: column; 
        }

        .content-header { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
        .content-body { padding: 2rem; flex-grow: 1; }

        .sidebar-footer { background: rgba(0,0,0,0.3); padding: 1.25rem; margin-top: auto; }
    </style>
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar shadow-lg">
            <div class="sidebar-header">
                <img src="~/images/logo-coem.png" alt="COEM" style="max-height: 40px; width: auto; filter: brightness(0) invert(1);">
            </div>

            <div class="px-3 mt-3">
                @if (isGlobalAdmin)
                {
                    <div class="badge bg-danger w-100 py-2 shadow-sm" style="font-size: 0.7rem; letter-spacing: 1px;">
                        <i class="bi bi-shield-fill-check me-1"></i> CONTROL TOTAL GLOBAL
                    </div>
                }
                else
                {
                    <div class="badge bg-primary w-100 py-2" style="font-size: 0.7rem;">
                        <i class="bi bi-geo-alt-fill me-1"></i> REGIÓN: @(TenantContext.CurrentCountry ?? "GENERAL")
                    </div>
                }
            </div>

            <nav class="sidebar-menu">
                <div class="menu-category">Operación Regional</div>
                <a href="/" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                
                @if (isGlobalAdmin)
                {
                    <a href="/Admin/Tenants" class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tenants" ? "active" : "")">
                        <i class="bi bi-building-fill"></i> Clientes
                    </a>
                }

                @if (isGlobalAdmin || (await AuthorizationService.AuthorizeAsync(User, "TenantSetup")).Succeeded)
                {
                    <div class="menu-category">Setup & Habilitación</div>
                    <a href="/Admin/Users" class="nav-link-custom nav-link-admin">
                        <i class="bi bi-people-fill"></i> Identidades
                    </a>
                    <a href="/Admin/CategoryMappings" class="nav-link-custom nav-link-admin">
                        <i class="bi bi-diagram-3-fill"></i> Mapeo de Categorías
                    </a>
                    <a href="/Admin/Countries" class="nav-link-custom nav-link-admin">
                        <i class="bi bi-suitcase-lg-fill"></i> Conexion Partner Center
                    </a>
                    <a href="/Admin/ExternalTenants" class="nav-link-custom nav-link-admin">
                        <i class="bi bi-server"></i> Conexion Externos
                    </a>
                }

                @if (isGlobalAdmin || (await AuthorizationService.AuthorizeAsync(User, "ViewBaseCosts")).Succeeded)
                {
                    <div class="menu-category">Negocio & FinOps</div>
                    <a href="/Admin/Billing" class="nav-link-custom">
                        <i class="bi bi-calculator-fill"></i> Reportes de Facturación
                    </a>
                    <a href="/Admin/Pricing" class="nav-link-custom">
                        <i class="bi bi-currency-exchange"></i> Gestión de Markups
                    </a>
                }
            </nav>

            <div class="sidebar-footer border-top border-secondary">
                @await Component.InvokeAsync("UserProfile")
            </div>
        </aside>

        <main class="main-content">
            <header class="content-header">
                <div class="fw-bold text-uppercase small text-muted">Portal de Gestión de Nube (CMP By COEM)</div>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-light text-dark border">@DateTime.Now.ToString("dd MMM yyyy")</span>
                    <a href="/MicrosoftIdentity/Account/SignOut" class="btn btn-sm btn-outline-danger border-0">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </header>

            <div class="content-body">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>