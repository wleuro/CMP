@model IEnumerable<Coem.Cmp.Core.Entities.Tenant>

@{
    ViewData["Title"] = "Gestión de Clientes CSP";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Clientes Activos (CSP)</h2>

        <div class="flex-grow-1 mx-4">
            <input type="text" id="searchInput" class="form-control form-control-lg shadow-sm border-secondary" placeholder="Buscar por cliente, dominio o Tenant ID..." autocomplete="off">
        </div>

        <div>
            <form asp-action="Sync" method="post" class="d-inline me-2">
                <button type="submit" class="btn btn-outline-secondary shadow-sm">
                    1. Identidades
                </button>
            </form>

            <form asp-action="SyncSubscriptions" method="post" class="d-inline">
                <button type="submit" class="btn btn-primary shadow-sm" onclick="return confirm('Esta operación tomará varios minutos para auditar todos los clientes. ¿Deseas continuar?');">
                    2. Auditar (Azure/Colab)
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>¡Ejecución Exitosa!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <strong>Error Operativo:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @{
        int totalAP = 0;
        int totalAL = 0;
        int totalColab = 0;
        int totalPendiente = 0;

        foreach (var tenant in Model)
        {
            bool hasAP = tenant.Subscriptions != null && tenant.Subscriptions.Any(s => s.Category == "AP");
            bool hasAL = tenant.Subscriptions != null && tenant.Subscriptions.Any(s => s.Category == "AL");
            bool hasColab = tenant.Subscriptions != null && tenant.Subscriptions.Any(s => s.Category == "Colab");

            if (hasAP) totalAP++;
            if (hasAL) totalAL++;
            if (hasColab && !hasAP && !hasAL) totalColab++;
            if (!hasAP && !hasAL && !hasColab) totalPendiente++;
        }
    }

    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card bg-primary text-white border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase fw-semibold mb-1 opacity-75">Azure Plan (AP)</h6>
                    <h2 class="display-6 fw-bold mb-0">@totalAP</h2>
                    <small class="opacity-75">Clientes en Nuevo Comercio</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase fw-semibold mb-1 opacity-75">Legacy (AL)</h6>
                    <h2 class="display-6 fw-bold mb-0">@totalAL</h2>
                    <small class="opacity-75">Requieren Migración Urgente</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light text-dark border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase fw-semibold mb-1 text-muted">Colaboración (M365)</h6>
                    <h2 class="display-6 fw-bold mb-0 text-secondary">@totalColab</h2>
                    <small class="text-muted">Portafolio Modern Work</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-white text-dark border shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-uppercase fw-semibold mb-1 text-muted">Sin Auditar</h6>
                    <h2 class="display-6 fw-bold mb-0 text-secondary">@totalPendiente</h2>
                    <small class="text-muted">Falta correr el Radar</small>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre del Cliente</th>
                        <th>Dominio Principal</th>
                        <th>Tenant ID</th>
                        <th>Perfil de Consumo</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                No hay clientes en la base de datos. Ejecuta la sincronización de identidades.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            bool hasAP = item.Subscriptions != null && item.Subscriptions.Any(s => s.Category == "AP");
                            bool hasAL = item.Subscriptions != null && item.Subscriptions.Any(s => s.Category == "AL");
                            bool hasColab = item.Subscriptions != null && item.Subscriptions.Any(s => s.Category == "Colab");

                            <tr>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td class="text-muted">@item.DefaultDomain</td>
                                <td><code class="text-secondary bg-light px-2 py-1 rounded">@item.MicrosoftTenantId</code></td>

                                <td>
                                    @if (hasAP || hasAL || hasColab)
                                    {
                                        if (hasAP)
                                        {
                                            <span class="badge bg-primary px-2 py-1 me-1 mb-1" title="Azure Plan (Modern Commerce)">AP</span>
                                        }
                                        if (hasAL)
                                        {
                                            <span class="badge bg-warning text-dark border border-warning px-2 py-1 me-1 mb-1" title="Azure Legacy (Requiere Migración)">AL</span>
                                        }
                                        if (hasColab && !hasAP && !hasAL)
                                        {
                                            <span class="badge bg-light text-secondary border px-2 py-1 me-1 mb-1">Colab</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-2 py-1">Sin clasificar</span>
                                    }
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2 py-1">Inactivo</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const tableRows = document.querySelectorAll('tbody tr');

            searchInput.addEventListener('keyup', function (e) {
                const term = e.target.value.toLowerCase();

                tableRows.forEach(row => {
                    // Si la fila es el mensaje de "No hay clientes", la ignoramos
                    if (row.cells.length === 1) return;

                    // Extraemos el texto de toda la fila para buscar por nombre, dominio o tag
                    const rowText = row.textContent.toLowerCase();

                    if (rowText.includes(term)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        });
    </script>
}