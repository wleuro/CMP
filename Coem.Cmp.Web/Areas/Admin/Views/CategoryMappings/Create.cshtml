@model Coem.Cmp.Core.Entities.CategoryMapping
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Id == 0 ? "Nueva Regla" : "Editar Regla";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom border-2">
                    <h4 class="mb-0 fw-normal">@(Model.Id == 0 ? "Crear Regla de Clasificación" : "Editar Regla")</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post">
                        @if (Model.Id != 0)
                        {
                            <input type="hidden" asp-for="Id" />
                        }

                        <div class="mb-4">
                            <label class="form-label fw-bold">Palabra Clave (Keyword)</label>
                            <input asp-for="Keyword" class="form-control form-control-lg" placeholder="Ej: INTUNE, COPILOT, AZURE PLAN" required />
                            <div class="form-text">Si el nombre del producto de Microsoft contiene esta palabra, se aplicará la regla.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Código de Categoría Destino</label>
                            <select asp-for="CategoryCode" class="form-select form-select-lg" required>
                                <option value="">Selecciona una categoría...</option>
                                <option value="M365">Colaboración y Modern Work (M365)</option>
                                <option value="AP">Consumo Azure (AP)</option>
                                <option value="INFRA">Infraestructura y Servidores (INFRA)</option>
                                <option value="DEV">Herramientas de Desarrollo (DEV)</option>
                                <option value="AL">Legacy / Otros (AL)</option>
                            </select>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Prioridad de Evaluación</label>
                                <input asp-for="Priority" type="number" class="form-control" required />
                                <div class="form-text">El motor evalúa primero la prioridad 1.</div>
                            </div>
                            <div class="col-md-6 d-flex align-items-center">
                                <div class="form-check form-switch mt-3">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="activeSwitch">
                                        <label class="form-check-label ms-2" for="activeSwitch">Regla Activa</label>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 border-top pt-4">
                                <a href="/Admin/CategoryMappings" class="btn btn-light border">Cancelar</a>
                                <button type="submit" class="btn btn-primary fw-bold px-4">Guardar Regla</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>