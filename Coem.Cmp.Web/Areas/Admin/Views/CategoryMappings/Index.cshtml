@model IEnumerable<Coem.Cmp.Core.Entities.CategoryMapping>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Consola de Clasificación - Zenith";
    var categories = ViewBag.Categories as List<Coem.Cmp.Core.Entities.CategoryDefinition>;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-dark text-uppercase">Motor de Clasificación FinOps</h2>
            <p class="text-muted mb-0 small">Arquitectura de lógica para el agrupamiento de costos de ebizzor.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark fw-bold rounded-0" onclick="openCategoryModal()">
                ADMINISTRAR CATEGORÍAS
            </button>
            <button class="btn btn-primary fw-bold px-4 shadow-sm rounded-0" onclick="openMappingModal()">
                NUEVA REGLA
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-0 border-0 shadow-sm mb-4" role="alert">
            <strong>ÉXITO:</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-0 border-0 shadow-sm mb-4" role="alert">
            <strong>ERROR:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="ps-4" style="width: 80px;">PRIO</th>
                        <th>PALABRA CLAVE (KEYWORD)</th>
                        <th>CATEGORÍA DESTINO</th>
                        <th class="text-center">ESTADO</th>
                        <th class="text-end pe-4">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted small">SIN REGLAS CONFIGURADAS.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsActive ? "" : "bg-light text-muted")">
                            <td class="ps-4">
                                <span class="badge bg-dark rounded-0">@item.Priority</span>
                            </td>
                            <td class="fw-bold">@item.Keyword</td>
                            <td>
                                <span class="badge bg-secondary rounded-0 px-2 py-1">
                                    @(categories?.FirstOrDefault(c => c.Code == item.CategoryCode)?.Name ?? item.CategoryCode)
                                </span>
                            </td>
                            <td class="text-center small fw-bold">
                                @(item.IsActive ? "ACTIVO" : "INACTIVO")
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-3">
                                    <button class="btn btn-sm btn-link text-primary p-0 fw-bold text-decoration-none" onclick="openMappingModal(@item.Id)">EDITAR</button>
                                    <button class="btn btn-sm btn-link text-danger p-0 fw-bold text-decoration-none" onclick="confirmDeleteMapping(@item.Id, '@item.Keyword')">ELIMINAR</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="fw-bold text-uppercase">Catálogo de Categorías (Sabores)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="resetCategoryForm()"></button>
            </div>
            <div class="modal-body p-4">
                <form id="categoryForm" asp-action="UpsertDefinition" method="post" class="bg-light p-3 rounded-0 mb-4 border">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="cat-id" value="0" />
                    <div class="row g-2">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">CÓDIGO</label>
                            <input name="Code" id="cat-code" class="form-control rounded-0" placeholder="Ej: M365" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">NOMBRE</label>
                            <input name="Name" id="cat-name" class="form-control rounded-0" placeholder="Ej: Modern Work" required />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-dark w-100 rounded-0 fw-bold" id="cat-save-btn">GUARDAR</button>
                        </div>
                    </div>
                </form>

                <h6 class="fw-bold mb-3 small text-muted text-uppercase">Existentes</h6>
                <div style="max-height: 250px; overflow-y: auto;" class="border">
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                            @if (categories != null)
                            {
                                foreach (var cat in categories)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@cat.Code</td>
                                        <td>@cat.Name</td>
                                        <td class="text-end pe-3">
                                            <button type="button" class="btn btn-sm btn-link text-primary text-decoration-none fw-bold" onclick="editCategory(@cat.Id)">EDITAR</button>
                                            <button type="button" class="btn btn-sm btn-link text-danger text-decoration-none fw-bold" onclick="confirmDeleteCategory(@cat.Id, '@cat.Name')">BORRAR</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mappingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="fw-bold text-uppercase" id="mappingTitle">Configuración de Regla</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="mappingForm" asp-action="Upsert" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="Id" id="map-id" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small">PALABRA CLAVE (KEYWORD)</label>
                        <input name="Keyword" id="map-kw" class="form-control rounded-0 text-uppercase" placeholder="Ej: AZURE PLAN" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">CATEGORÍA DESTINO</label>
                        <select name="CategoryCode" id="map-cat" class="form-select rounded-0" required>
                            <option value="">Seleccionar sabor...</option>
                            @if (categories != null)
                            {
                                foreach (var cat in categories)
                                {
                                    <option value="@cat.Code">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label fw-bold small">PRIORIDAD</label>
                            <input name="Priority" id="map-prio" type="number" class="form-control rounded-0" value="10" required />
                        </div>
                        <div class="col-6 d-flex align-items-center">
                            <div class="form-check form-switch mt-4">
                                <input name="IsActive" id="map-active" class="form-check-input" type="checkbox" value="true" checked />
                                <label class="form-check-label fw-bold small ms-2">ACTIVA</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0">
                    <button type="button" class="btn btn-light border rounded-0" data-bs-dismiss="modal">CANCELAR</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold rounded-0">GUARDAR REGLA</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteMappingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-body p-4 text-center">
                <h6 class="fw-bold mb-3">¿ELIMINAR REGLA?</h6>
                <p class="text-muted small mb-4">Se borrará la lógica para: <br><strong id="del-map-label" class="text-dark"></strong></p>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="del-map-id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger fw-bold rounded-0">CONFIRMAR</button>
                        <button type="button" class="btn btn-light border rounded-0" data-bs-dismiss="modal">CANCELAR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-body p-4 text-center">
                <h6 class="fw-bold mb-3">¿BORRAR CATEGORÍA?</h6>
                <p class="text-muted small mb-3">Sabor: <strong id="del-cat-label" class="text-dark"></strong></p>
                <form asp-action="DeleteDefinition" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="del-cat-id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger fw-bold rounded-0">ELIMINAR DEFINICIÓN</button>
                        <button type="button" class="btn btn-light border rounded-0" data-bs-dismiss="modal">CANCELAR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const mapModal = new bootstrap.Modal(document.getElementById('mappingModal'));
        const catModal = new bootstrap.Modal(document.getElementById('categoryModal'));
        const delMapModal = new bootstrap.Modal(document.getElementById('deleteMappingModal'));
        const delCatModal = new bootstrap.Modal(document.getElementById('deleteCategoryModal'));

        function openMappingModal(id = 0) {
            document.getElementById('mappingForm').reset();
            document.getElementById('map-id').value = id;
            document.getElementById('mappingTitle').innerText = id === 0 ? "NUEVA REGLA" : "EDITAR REGLA";
            if (id > 0) {
                fetch(`/Admin/CategoryMappings/GetMapping/${id}`).then(r => r.json()).then(data => {
                    document.getElementById('map-kw').value = data.keyword;
                    document.getElementById('map-cat').value = data.categoryCode;
                    document.getElementById('map-prio').value = data.priority;
                    document.getElementById('map-active').checked = data.isActive;
                    mapModal.show();
                });
            } else { mapModal.show(); }
        }

        function confirmDeleteMapping(id, label) {
            document.getElementById('del-map-id').value = id;
            document.getElementById('del-map-label').innerText = label;
            delMapModal.show();
        }

        function openCategoryModal() { resetCategoryForm(); catModal.show(); }

        function editCategory(id) {
            fetch(`/Admin/CategoryMappings/GetCategoryDefinition/${id}`).then(r => r.json()).then(data => {
                document.getElementById('cat-id').value = data.id;
                document.getElementById('cat-code').value = data.code;
                document.getElementById('cat-name').value = data.name;
                document.getElementById('cat-save-btn').innerText = "ACTUALIZAR";
                document.getElementById('cat-code').readOnly = true;
            });
        }

        function confirmDeleteCategory(id, label) {
            document.getElementById('del-cat-id').value = id;
            document.getElementById('del-cat-label').innerText = label;
            delCatModal.show();
        }

        function resetCategoryForm() {
            document.getElementById('categoryForm').reset();
            document.getElementById('cat-id').value = "0";
            document.getElementById('cat-save-btn').innerText = "GUARDAR";
            document.getElementById('cat-code').readOnly = false;
        }
    </script>
}