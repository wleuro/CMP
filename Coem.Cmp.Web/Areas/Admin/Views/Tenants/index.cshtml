@model IEnumerable<Coem.Cmp.Core.Entities.Tenant>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Radar de Clientes"; // Eliminado término restringido

    var countries = ViewBag.Countries as List<string>;
    var currentFilter = ViewBag.CurrentFilter as string;
    var searchQuery = ViewBag.SearchQuery as string;
    var categoryFilter = ViewBag.CategoryFilter as string;
}

<style>
    /* Estética de Alto Nivel: Redondeado Táctico */
    .btn { border-radius: 50rem !important; transition: all 0.3s ease; }
    .kpi-card { border-radius: 1.25rem !important; cursor: pointer; transition: all 0.2s ease; border: 1px solid rgba(0,0,0,0.05) !important; min-height: 85px; }
    .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; filter: brightness(1.05); }
    .kpi-inactive { opacity: 0.2; filter: grayscale(90%); }
    
    /* RECONSTRUCCIÓN DE BANDERAS (Gradientes Precisos 50/25/25) */
    .flag-co, .flag-ec {
        background: linear-gradient(to bottom, 
            #FFCD00 0%, #FFCD00 50%, 
            #003087 50%, #003087 75%, 
            #C8102E 75%, #C8102E 100%) !important;
        color: white !important;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        border: none !important;
    }
    .flag-pe { background: linear-gradient(to right, #D91023 33%, #FFF 33% 66%, #D91023 66%); color: #000 !important; border: 1px solid #eee !important; }
    .flag-cr { background: linear-gradient(to bottom, #001489 16%, #FFF 16% 33%, #DA291C 33% 66%, #FFF 66% 83%, #001489 83%); color: white !important; }
    .flag-bo { background: linear-gradient(to bottom, #DA291C 33%, #F4E400 33% 66%, #007A33 66%); color: white !important; }
    .flag-pa { background: linear-gradient(to right, #FFF 50%, #DA291C 50%) top / 100% 50% no-repeat, linear-gradient(to right, #001489 50%, #FFF 50%) bottom / 100% 50% no-repeat; color: white !important; }
    
    .badge-rounded { border-radius: 50rem !important; padding: 0.4em 1em !important; }
    .pulse-success { display: inline-block; width: 8px; height: 8px; background-color: #10b981; border-radius: 50%; margin-right: 5px; animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); } 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); } }
</style>

<div class="container-fluid mt-4">

    @* Cabecera y Controles Principales *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold text-uppercase">Radar Regional de Clientes</h2>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-dark bg-white fw-bold shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#syncIdentitiesModal">1. SINCRONIZAR TENANTS</button>
            <button type="button" class="btn btn-primary fw-bold shadow-sm border-0 px-4" style="background-color: #109DFA;" data-bs-toggle="modal" data-bs-target="#syncSubscriptionsModal">2. AUDITORÍA DE SERVICIOS</button>
        </div>
    </div>

    @* Feedback de Operación *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4 mb-4 px-4 py-3" role="alert">
            <div class="d-flex align-items-center">
                <strong class="me-2 text-uppercase">Éxito Operativo:</strong> @TempData["SuccessMessage"]
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* KPIs Operativos: 12 Categorías Estratégicas *@
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-2 mb-4">
        @* Fila 1 *@
        <div class="col" onclick="toggleCategoryFilter('AP')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "AP" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #109DFA; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">AZURE PLAN</small><h3 class="fw-bold mb-0">@ViewBag.TotalAP</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('M365')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "M365" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #FFBF06; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">M365</small><h3 class="fw-bold mb-0">@ViewBag.TotalM365</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('AI')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "AI" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #00B5B5; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">AI</small><h3 class="fw-bold mb-0">@ViewBag.TotalAI</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('SEGURIDAD')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "SEG" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #0DC400; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">SEGURIDAD</small><h3 class="fw-bold mb-0">@ViewBag.TotalSeguridad</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('POWERPLATFORM')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "POWERPLATFORM" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #7C3AED; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">POWER PLAT.</small><h3 class="fw-bold mb-0">@ViewBag.TotalPowerPlatform</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('TELEFONIA')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "TEL" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #10B981; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">TELEFONÍA</small><h3 class="fw-bold mb-0">@ViewBag.TotalTelefonia</h3></div>
            </div>
        </div>
        
        @* Fila 2 *@
        <div class="col" onclick="toggleCategoryFilter('DYNAMICS')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "DYN" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #E3008C; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">DYNAMICS</small><h3 class="fw-bold mb-0">@ViewBag.TotalDynamics</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('BI')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "BI" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #F2C811; color: black;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">BI / DATA</small><h3 class="fw-bold mb-0">@ViewBag.TotalBI</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('INFRA')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "INFRA" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #23BAC4; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">INFRA</small><h3 class="fw-bold mb-0">@ViewBag.TotalInfra</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('DEV')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "DEV" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #E69DFB; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">DEV</small><h3 class="fw-bold mb-0">@ViewBag.TotalDev</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('AL')">
            <div class="card shadow-sm h-100 border-0 kpi-card @(categoryFilter == "AL" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))" style="background-color: #E36B2F; color: white;">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1">LEGACY</small><h3 class="fw-bold mb-0">@ViewBag.TotalAL</h3></div>
            </div>
        </div>
        <div class="col" onclick="toggleCategoryFilter('None')">
            <div class="card shadow-sm h-100 border-0 bg-white kpi-card border @(categoryFilter == "None" ? "" : (categoryFilter != null ? "kpi-inactive" : ""))">
                <div class="card-body p-2 text-center"><small class="fw-bold d-block mb-1 text-dark">REVISIÓN</small><h3 class="fw-bold mb-0 text-dark">@ViewBag.EnRevision</h3></div>
            </div>
        </div>
    </div>

    @* Filtros de Búsqueda Redondeados *@
    <div class="card shadow-sm border-0 mb-4 bg-light rounded-4">
        <div class="card-body py-3">
            <form id="radarForm" method="get" action="/Admin/Tenants" class="row g-2 align-items-center">
                <input type="hidden" name="categoryFilter" id="categoryFilter" value="@categoryFilter" />
                <div class="col-md-3">
                    <select name="countryFilter" class="form-select border-0 shadow-sm rounded-pill px-4" onchange="this.form.submit()">
                        <option value="">🌍 TODA LA REGIÓN</option>
                        @foreach (var country in countries ?? new List<string>())
                        {
                            <option value="@country" selected="@(currentFilter == country)">@country.ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white">
                        <input type="text" name="searchQuery" class="form-control border-0 px-4" placeholder="Buscar por cliente, dominio o ID..." value="@searchQuery" />
                        <button class="btn btn-link text-muted border-0 pe-4" type="submit">🔍</button>
                    </div>
                </div>
                <div class="col-auto ms-auto"><span class="badge bg-dark fs-6 px-4 py-2 badge-rounded shadow-sm">VISIBLES: @Model.Count()</span></div>
            </form>
        </div>
    </div>

    @* Tabla Maestro-Detalle *@
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-white border-bottom border-2 text-uppercase small fw-bold">
                    <tr>
                        <th class="py-3 px-4">Nombre del Cliente</th>
                        <th>Dominio Principal</th>
                        <th>Tenant ID</th>
                        <th class="text-center">Subsidiaria</th>
                        <th class="text-center">Perfil de Consumo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        string currentCountry = item.Country?.Trim() ?? "";
                        string flagCss = currentCountry switch { "Colombia" => "flag-co", "Ecuador" => "flag-ec", "Perú" => "flag-pe", "Peru" => "flag-pe", "Costa Rica" => "flag-cr", "Bolivia" => "flag-bo", "Panamá" => "flag-pa", "Panama" => "flag-pa", _ => "flag-default" };

                        <tr style="border-bottom: 1px solid #f3f4f6;">
                            <td class="fw-bold px-4 text-primary">@item.Name</td>
                            <td class="text-muted small">@item.DefaultDomain</td>
                            <td><small class="text-muted" style="font-family: monospace;">@item.MicrosoftTenantId</small></td>
                            <td class="text-center"><span class="badge badge-rounded shadow-sm @flagCss">@item.Country</span></td>
                            <td class="text-center">
                                <div class="d-flex flex-wrap justify-content-center gap-2">
                                    @if (!item.Subscriptions.Any())
                                    {
                                        <span class="badge badge-rounded shadow-sm border text-dark bg-white">REVISIÓN</span>
                                    }
                                    else
                                    {
                                        @foreach (var group in item.Subscriptions.GroupBy(s => s.Category))
                                        {
                                            string catStyle = group.Key switch
                                            {
                                                "AP" => "background-color: #109DFA; color: white;",
                                                "M365" => "background-color: #FFBF06; color: white;",
                                                "AI" => "background-color: #00B5B5; color: white;",
                                                "SEGURIDAD" => "background-color: #0DC400; color: white;",
                                                "POWERPLATFORM" => "background-color: #7C3AED; color: white;",
                                                "TELEFONIA" => "background-color: #10B981; color: white;",
                                                "DYNAMICS" => "background-color: #E3008C; color: white;",
                                                "BI" => "background-color: #F2C811; color: black;",
                                                "INFRA" => "background-color: #23BAC4; color: white;",
                                                "DEV" => "background-color: #E69DFB; color: white;",
                                                "AL" => "background-color: #E36B2F; color: white;",
                                                _ => "background-color: #FFFFFF; color: black; border: 1px solid #dee2e6;"
                                            };

                                            // CORRECCIÓN: s.OfferName -> s.Name y s.Id -> s.MicrosoftSubscriptionId para el GUID
                                            var subsJson = System.Text.Json.JsonSerializer.Serialize(group.Select(s => new {
                                                id = s.MicrosoftSubscriptionId,
                                                name = s.Name,
                                                status = s.Status.ToLower(),
                                                createdDate = s.CreatedDate.ToString("yyyy-MM-dd"),
                                                modifiedDate = s.EffectiveDate?.ToString("yyyy-MM-dd") ?? "Sin cambios"
                                            }));

                                            <span class="badge badge-rounded shadow-sm badge-clickable text-uppercase" style="@catStyle; font-size: 0.7rem;" onclick="showSubscriptionDetails('@item.Name', '@group.Key', @subsJson)">
                                                @group.Key (@group.Count())
                                            </span>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* MODALES DE OPERACIÓN *@

<div class="modal fade" id="syncIdentitiesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-light border-0 px-4 py-3">
                <h5 class="modal-title fw-bold">Sincronizar Directorio de Clientes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <p class="mb-0 text-muted">¿Deseas actualizar la lista regional de Tenants desde Microsoft Partner Center? Este proceso no afecta las suscripciones.</p>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <form action="/Admin/Tenants/Sync" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-dark px-4 fw-bold shadow-sm">Confirmar Sincronización</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="syncSubscriptionsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 px-4 py-3" style="background-color: #109DFA; color: white;">
                <h5 class="modal-title fw-bold">Auditoría Total de Servicios</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <p class="mb-2"><strong>¡Aviso Crítico!</strong></p>
                <p class="text-muted">Se realizará un barrido completo de licencias SaaS (M365, Dynamics, BI) y suscripciones Azure para todos los clientes. <br><br><strong>Esto aplicará las nuevas reglas de clasificación a todo el inventario.</strong></p>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <form action="/Admin/Tenants/SyncSubscriptions" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm" style="background-color: #109DFA; border:none;">Iniciar Auditoría Total</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="subDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 bg-light px-4 py-3">
                <h5 class="modal-title fw-bold" id="modalSubTitle">Detalle Técnico de Servicios</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light text-uppercase small fw-bold">
                            <tr>
                                <th class="ps-4">Servicio / Oferta</th>
                                <th>GUID (MS)</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">F. Creación</th>
                                <th class="text-center pe-4">Última Modificación</th>
                            </tr>
                        </thead>
                        <tbody id="modalSubBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentSubs = [];

        function toggleCategoryFilter(category) {
            var input = document.getElementById('categoryFilter');
            input.value = (input.value === category) ? "" : category;
            document.getElementById('radarForm').submit();
        }

        function showSubscriptionDetails(clientName, category, subs) {
            currentSubs = subs;
            renderModalBody();
            document.getElementById('modalSubTitle').innerHTML = `<span class="text-primary">${clientName}</span> - <small class="text-muted text-uppercase">${category}</small>`;
            new bootstrap.Modal(document.getElementById('subDetailModal')).show();
        }

        function renderModalBody() {
            let html = '';
            currentSubs.forEach(s => {
                let statusBadge = s.status === 'active' 
                    ? `<span class="badge badge-rounded bg-success"><span class="pulse-success"></span>ACTIVA (RUNNING)</span>` 
                    : `<span class="badge badge-rounded bg-danger">${s.status.toUpperCase()}</span>`;
                html += `<tr>
                    <td class="ps-4 fw-bold text-dark small">${s.name}</td>
                    <td class="text-muted" style="font-family:monospace; font-size: 0.75rem;">${s.id}</td>
                    <td class="text-center">${statusBadge}</td>
                    <td class="text-center text-muted small">${s.createdDate}</td>
                    <td class="text-center fw-bold pe-4 text-primary small">${s.modifiedDate}</td>
                </tr>`;
            });
            document.getElementById('modalSubBody').innerHTML = html;
        }
    </script>
}