@model IEnumerable<Coem.Cmp.Web.Areas.Admin.ViewModels.UserListViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Gestión Staff COEM";
}

<div class="container-fluid py-4 px-xl-5">
    
    @* ALERTAS DE SISTEMA *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 12px; background-color: #E1FCEF; color: #14804A;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bolder mb-1" style="color: var(--sidebar-bg); font-size: 1.75rem;">Staff Corporativo</h2>
            <p class="mb-0" style="color: var(--text-muted); font-size: 0.9rem;">Gestión de identidades y roles internos de Controles Empresariales.</p>
        </div>
        <div>
            <button class="btn btn-primary border-0 shadow-sm d-flex align-items-center gap-2 py-2 px-4" data-bs-toggle="modal" data-bs-target="#modalNuevoUsuario" style="border-radius: 10px; background-color: var(--accent-color);">
                <i class="bi bi-person-plus-fill"></i>
                Registrar Colaborador
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px; background: white;">
        <div class="card-body p-0">
            <div class="d-flex justify-content-between align-items-center p-4">
                <div class="position-relative" style="width: 350px;">
                    <i class="bi bi-search position-absolute" style="top: 10px; left: 15px; color: var(--text-muted);"></i>
                    <input type="text" id="userSearch" class="form-control bg-light border-0 ps-5 py-2" placeholder="Buscar por nombre o email..." style="border-radius: 10px; font-size: 0.875rem;">
                </div>
                <div class="badge bg-light text-muted border py-2 px-3" style="border-radius: 8px;">
                    Total Staff: @Model.Count()
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0" id="usersTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 py-3 text-muted small text-uppercase fw-bold">Colaborador</th>
                            <th class="border-0 py-3 text-muted small text-uppercase fw-bold">Rol de Negocio</th>
                            <th class="border-0 py-3 text-muted small text-uppercase fw-bold">País / Región</th>
                            <th class="border-0 py-3 text-muted small text-uppercase fw-bold">Estado</th>
                            <th class="pe-4 border-0 py-3 text-end text-muted small text-uppercase fw-bold">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">No hay personal registrado en el radar de COEM.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; background: rgba(59, 130, 246, 0.1); color: var(--accent-color);">
                                                @(user.DisplayName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@user.DisplayName</div>
                                                <div class="text-muted small">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-white border text-dark fw-medium px-3 py-2" style="border-radius: 8px;">
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@(user.TenantName == "Staff Corporativo" ? "Global" : user.TenantName)</span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2" style="border-radius: 8px;">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2" style="border-radius: 8px;">Bloqueado</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-light border" title="Cambiar Estado">
                                                    <i class="bi bi-power @(user.IsActive ? "text-success" : "text-danger")"></i>
                                                </button>
                                            </form>

                                            <button class="btn btn-sm btn-light border"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalEliminarUsuario"
                                                    data-id="@user.Id"
                                                    data-name="@user.DisplayName"
                                                    title="Eliminar">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* MODAL: REGISTRAR COLABORADOR *@
<div class="modal fade" id="modalNuevoUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" style="color: var(--sidebar-bg);">Registrar Colaborador COEM</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-controller="Users" asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Correo Corporativo (UPN)</label>
                        <input type="email" name="Upn" class="form-control bg-light border-0 py-2" placeholder="ej. w.lopez@controlesempresariales.com" required style="border-radius: 8px;">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Rol Interno</label>
                            <select name="RoleId" class="form-select bg-light border-0 py-2" required style="border-radius: 8px;"
                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Roles">
                                <option value="">Seleccione Rol...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">País / Región</label>
                            <select name="Country" class="form-select bg-light border-0 py-2" style="border-radius: 8px;"
                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Countries">
                                <option value="">Opcional...</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light fw-bold py-2 px-4" data-bs-dismiss="modal" style="border-radius: 8px;">Cancelar</button>
                    <button type="submit" class="btn btn-primary fw-bold py-2 px-4" style="border-radius: 8px; background-color: var(--accent-color);">Autorizar Acceso</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* MODAL: CONFIRMAR ELIMINACIÓN *@
<div class="modal fade" id="modalEliminarUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-danger">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p>¿Estás seguro de que deseas eliminar a <strong id="deleteUserName"></strong>? Esta acción purgará su perfil de la base de datos de COEM.</p>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" id="deleteUserId" />
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger fw-bold px-4">Eliminar Definitivamente</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lógica de búsqueda rápida
        document.getElementById('userSearch').addEventListener('keyup', function() {
            let value = this.value.toLowerCase();
            let rows = document.querySelectorAll('#usersTable tbody tr');
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(value) ? '' : 'none';
            });
        });

        // Carga de datos en el modal de eliminación
        const modalEliminar = document.getElementById('modalEliminarUsuario');
        modalEliminar.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');
            
            document.getElementById('deleteUserId').value = id;
            document.getElementById('deleteUserName').textContent = name;
        });
    </script>
}